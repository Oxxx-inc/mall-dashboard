# ============================================
# Amazon広告API 認証情報
# ============================================
# ⚠️ このファイルは .gitignore に含まれています
# ⚠️ Gitにコミットしないでください
# Railway にデプロイする場合は Variables タブで設定してください

# Amazon Advertising Console で発行
CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth認証で取得したRefresh Token
REFRESH_TOKEN=Atzr|IwEBIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 日本マーケットのProfile ID（/v2/profiles で確認）
PROFILE_ID=1234567890

# ============================================
# チームアクセス制限（任意）
# ============================================
# 設定するとAPIアクセスに x-team-token ヘッダーが必要になります
# 未設定の場合は認証なしでアクセス可能
TEAM_TOKEN=your-secret-team-token-here

# ============================================
# サーバー設定
# ============================================
# Railway が自動設定するため通常は変更不要
PORT=3001
